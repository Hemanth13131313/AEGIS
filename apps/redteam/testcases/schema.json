{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AEGIS Red Team Test Case",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "atlas_technique", "owasp_category", "version", "prompt", "expected_action"],
    "properties": {
      "id": {"type": "string", "pattern": "^RT-(LLM[0-9]{2}|SAFE)-[0-9]{3}$"},
      "name": {"type": "string"},
      "atlas_technique": {"type": "string"},
      "owasp_category": {"type": "string"},
      "version": {"type": "integer", "minimum": 1},
      "prompt": {"type": "string"},
      "expected_action": {"type": "string", "enum": ["allow", "block", "redact", "tag"]}
    }
  }
}
