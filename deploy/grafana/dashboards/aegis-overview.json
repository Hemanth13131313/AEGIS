{
  "uid": "aegis-overview",
  "title": "AEGIS — Security Overview",
  "tags": ["aegis", "overview"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests (today)",
      "targets": [{ "expr": "sum(increase(http_requests_total{service=\"aegis-gateway\"}[24h]))", "refId": "A" }],
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Block Rate %",
      "targets": [{ "expr": "sum(rate(aegis_scanner_requests_total{action=\"block\"}[5m])) / sum(rate(aegis_scanner_requests_total[5m])) * 100", "refId": "A" }],
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 0 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "P95 Gateway Latency",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"aegis-gateway\"}[5m])) by (le)) * 1000", "refId": "A" }],
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 10 }] } } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Scanner P95 Latency",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(aegis_scanner_latency_seconds_bucket[5m])) by (le)) * 1000", "refId": "A" }],
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 500 }] } } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Availability",
      "targets": [{ "expr": "avg_over_time(up{job=~\"aegis.*\"}[24h]) * 100", "refId": "A" }],
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Requests/sec",
      "targets": [{ "expr": "sum(rate(http_requests_total{service=\"aegis-gateway\"}[1m]))", "refId": "A" }],
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Detection Actions",
      "targets": [{ "expr": "sum(rate(aegis_scanner_requests_total[1m])) by (action)", "refId": "A" }],
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Policy Engine Check Latency",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(aegis_gateway_policy_check_duration_seconds_bucket[1m])) by (le)) * 1000", "refId": "A" }],
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 }
    },
    {
      "id": 9,
      "type": "gauge",
      "title": "Ensemble Disagreement Ratio",
      "targets": [{ "expr": "aegis_scanner_disagreement_ratio", "refId": "A" }],
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.2 }] } } }
    },
    {
      "id": 10,
      "type": "table",
      "title": "Recent Detections",
      "targets": [{ "expr": "topk(10, sum(rate(aegis_scanner_requests_total{action=\"block\"}[5m])) by (rule_id, owasp_category))", "refId": "A", "format": "table" }],
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 }
    }
  ]
}
